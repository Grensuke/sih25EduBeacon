# Copy this file to `.env` in the same directory (never commit `.env`).
#   cp .env.example .env
# Or from EduBeacon root: npm run setup

NODE_ENV=development
PORT=5000

MONGODB_URI=mongodb://localhost:27017/edubeacon

JWT_SECRET=change-me-to-a-long-random-secret

GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_API_VERSION=v1beta

# Comma-separated frontend origins (optional; defaults include localhost + Vercel URLs)
# ALLOWED_ORIGINS=http://localhost:3000,https://sih25edubeacon.vercel.app

# Set to "true" on production after your first admin exists
# DISABLE_PUBLIC_ADMIN_REGISTER=true
